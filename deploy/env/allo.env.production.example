# ============================================
# Allo 生产环境配置文件
# ============================================
# 复制此文件到 /etc/allo/allo.env 并修改所有标记为 CHANGE_ME 的值

# ============================================
# 数据库配置（必填）
# ============================================
DATABASE_URL=postgresql+asyncpg://allo:CHANGE_ME_POSTGRES_PASSWORD@127.0.0.1:5432/allo
CHECKPOINT_POSTGRES_URI=postgresql://allo:CHANGE_ME_POSTGRES_PASSWORD@127.0.0.1:5432/allo

# ============================================
# Redis 配置（必填）
# ============================================
REDIS_URL=redis://:CHANGE_ME_REDIS_PASSWORD@127.0.0.1:6379/0

# ============================================
# 安全密钥（必填，生成方法见下方）
# ============================================
# 生成随机密钥：python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=CHANGE_ME_GENERATE_RANDOM_32_CHARS
API_KEY_ENCRYPTION_SECRET=CHANGE_ME_GENERATE_RANDOM_32_CHARS

# ============================================
# 应用配置
# ============================================
# 应用环境
NODE_ENV=production
PYTHON_ENV=production

# 日志级别
LOG_LEVEL=info

# 允许的来源（CORS）
ALLOWED_ORIGINS=http://YOUR_SERVER_IP

# ============================================
# 平台模型服务 API Key（必填至少一个）
# ============================================
# OpenAI
OPENAI_API_KEY=sk-CHANGE_ME

# Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# 火山引擎
VOLCENGINE_API_KEY=CHANGE_ME

# DeepSeek
DEEPSEEK_API_KEY=sk-CHANGE_ME

# ============================================
# 搜索引擎 API Key（可选）
# ============================================
# Tavily 搜索
TAVILY_API_KEY=tvly-CHANGE_ME

# Jina AI
JINA_API_KEY=jina_CHANGE_ME

# ============================================
# 限流配置（可选）
# ============================================
# 每用户每分钟最大请求数
MAX_REQUESTS_PER_MINUTE=60

# 每组织每分钟最大请求数
MAX_ORG_REQUESTS_PER_MINUTE=300

# ============================================
# Sandbox 配置（可选）
# ============================================
# Sandbox 类型：local 或 docker
SANDBOX_TYPE=local

# 每用户最大 sandbox 数量
MAX_SANDBOXES_PER_USER=2

# Sandbox 空闲超时（秒）
SANDBOX_IDLE_TIMEOUT=600

# ============================================
# 文件存储配置
# ============================================
# 用户数据根目录
USER_DATA_DIR=/var/lib/allo/users

# 最大上传文件大小（MB）
MAX_UPLOAD_SIZE_MB=50

# ============================================
# 前端配置
# ============================================
# Better Auth Secret（前端构建时需要）
BETTER_AUTH_SECRET=CHANGE_ME_GENERATE_RANDOM_32_CHARS

# Next.js 公开 URL
NEXT_PUBLIC_APP_URL=http://YOUR_SERVER_IP

# Gateway API URL（前端调用）
NEXT_PUBLIC_GATEWAY_URL=http://YOUR_SERVER_IP/api

# LangGraph API URL（前端 SDK 调用）
NEXT_PUBLIC_LANGGRAPH_URL=http://YOUR_SERVER_IP/api/langgraph

# ============================================
# 可观测性（可选）
# ============================================
# Sentry DSN（错误追踪）
# SENTRY_DSN=

# ============================================
# 开发模式开关（生产环境必须关闭）
# ============================================
# 跳过认证（仅开发）
SKIP_AUTH=0

# 跳过环境变量验证（仅开发）
SKIP_ENV_VALIDATION=0

# ============================================
# 备注
# ============================================
# 1. 所有 CHANGE_ME 必须替换为实际值
# 2. 密码和密钥必须使用强随机字符串
# 3. 生产环境禁止使用默认密码
# 4. 此文件包含敏感信息，权限应设为 600
#    chmod 600 /etc/allo/allo.env
#    chown allo:allo /etc/allo/allo.env
